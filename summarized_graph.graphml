      <data key="d1" />
      <data key="d2">f0d559329d874e435f04be915b85b185</data>
    </node>
    <node id="&quot;THE RETIREMENT HOME&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"The Retirement Home is a facility where elderly patients are quarantined and treated during the coronavirus outbreak, raising concerns among family members."</data>
      <data key="d2">3b5ca06477ea6649725a16d09d87927a</data>
    </node>
    <node id="&quot;VEGETABLE DONATIONS&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"Vegetable Donations refer to the efforts made to provide food to those in need during the pandemic, which have faced logistical challenges."</data>
      <data key="d2">3b5ca06477ea6649725a16d09d87927a</data>
    </node>
    <node id="&quot;AD&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"AD is an individual who proposed a suggestion regarding the management of the coronavirus outbreak, which sparked public debate about privacy and safety."</data>
      <data key="d2">0ea87bb3f7f4f08e19bd21127da9be59</data>
    </node>
    <node id="&quot;DOCTOR FRIENDS&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Doctor friends are medical professionals who provide insights and updates about the coronavirus situation, particularly regarding its spread and control."</data>
      <data key="d2">0ea87bb3f7f4f08e19bd21127da9be59</data>
    </node>
    <node id="&quot;NATIONAL EMERGENCY RESPONSE SYSTEM&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"The National Emergency Response System is a framework established to manage crises like the coronavirus outbreak, emphasizing the need for effective measures to control the situation."</data>
      <data key="d2">0ea87bb3f7f4f08e19bd21127da9be59</data>
    </node>
    <node id="&quot;PROFESSOR DAI JIANYE&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Professor Dai Jianye is a figure mentioned in the context of criticism related to the Yangtze Daily, indicating involvement in public discourse about the pandemic."</data>
      <data key="d2">e27a49f034d2f2f425ddd0e46dee9822</data>
    </node>
    <node id="&quot;WORLD HEALTH ORGANIZATION&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"The World Health Organization is an international health agency that has representatives in Beijing, providing information on effective treatments for the coronavirus."</data>
      <data key="d2">e27a49f034d2f2f425ddd0e46dee9822</data>
    </node>
    <node id="&quot;FEBRUARY 26, 2020&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"February 26, 2020, is the date on which the observations and reflections regarding the coronavirus outbreak and its impact are recorded."</data>
      <data key="d2">e27a49f034d2f2f425ddd0e46dee9822</data>
    </node>
    <node id="&quot;THE DOCTORS&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"The Doctors are healthcare professionals working tirelessly to manage and treat patients affected by the coronavirus outbreak."</data>
      <data key="d2">a45ab7ca6e1942a4732b13ef47f6587f</data>
    </node>
    <node id="&quot;THE HOSPITAL SYSTEM&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"The Hospital System refers to the network of hospitals dealing with the influx of patients during the coronavirus outbreak, facing challenges in patient admissions."</data>
      <data key="d2">a45ab7ca6e1942a4732b13ef47f6587f</data>
    </node>
    <node id="&quot;THE FLOATING POPULATION&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"The Floating Population refers to individuals who are marginalized and may be unreported cases of coronavirus, contributing to the spread of the virus."</data>
      <data key="d2">a45ab7ca6e1942a4732b13ef47f6587f</data>
    </node>
    <node id="&quot;THE ELDERLY&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"The Elderly refers to older individuals who are particularly vulnerable to the coronavirus and face challenges in accessing hospital care."</data>
      <data key="d2">a45ab7ca6e1942a4732b13ef47f6587f</data>
    </node>
    <node id="&quot;HUANGGANG&quot;">
      <data key="d0">"GEO"</data>
      <data key="d1">"Huanggang is a region near Wuhan that has faced challenges due to the coronavirus outbreak but has reportedly improved its disease prevention measures."</data>
      <data key="d2">a784bfe671571202f52c5445629f1862</data>
    </node>
    <node id="&quot;LUOTIAN HOT SPRINGS&quot;">
      <data key="d0">"GEO"</data>
      <data key="d1">"Luotian Hot Springs is a location where national forces provided support and medical teams were sent for rest after managing the outbreak in Huanggang."</data>
      <data key="d2">a784bfe671571202f52c5445629f1862</data>
    </node>
    <node id="&quot;LIU XUERONG&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Liu Xuerong is identified as the Huanggang Party Secretary, known for implementing significant measures during the coronavirus outbreak."</data>
      <data key="d2">a784bfe671571202f52c5445629f1862</data>
    </node>
    <node id="&quot;PROFESSOR WANG LIMING&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Professor Wang Liming is a scientist from Zhejiang University who provided insights on the complexities of modern science and public health during an interview."</data>
      <data key="d2">a784bfe671571202f52c5445629f1862</data>
    </node>
    <node id="&quot;CAIJING MAGAZINE&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"Caijing Magazine is a publication that featured an interview with Professor Wang Liming, discussing public health and scientific perspectives."</data>
      <data key="d2">a784bfe671571202f52c5445629f1862</data>
    </node>
    <node id="&quot;THE FIRST GROUP OF MEDICAL VOLUNTEERS&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"The First Group of Medical Volunteers refers to the initial team sent to Hubei to assist in managing the coronavirus outbreak."</data>
      <data key="d2">a784bfe671571202f52c5445629f1862</data>
    </node>
    <node id="&quot;THE NOVEL CORONAVIRUS&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">The Novel Coronavirus is the virus responsible for the outbreak that has resulted in widespread infection and fatalities. This virus has prompted extensive quarantine measures and health protocols, particularly in Wuhan and other affected areas. Its emergence has significantly impacted public health and safety, leading to global responses aimed at controlling its spread.</data>
      <data key="d2">603d63bc59fd873441e2c2b5e86f64e6,a784bfe671571202f52c5445629f1862</data>
    </node>
    <node id="&quot;DR. XIA SISI&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Dr. Xia Sisi was a physician who tragically died during the outbreak, prompting discussions about the safety of medical personnel on the front lines."</data>
      <data key="d2">8119bda66f27343b4be177610dcff2af</data>
    </node>
    <node id="&quot;XIA SISI'S HUSBAND&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Xia Sisi's husband is a physician being urged to reconsider his role on the front lines after the loss of his wife."</data>
      <data key="d2">8119bda66f27343b4be177610dcff2af</data>
    </node>
    <node id="&quot;SOLE SURVIVOR POLICY&quot;">
      <data key="d0">"CONCEPT"</data>
      <data key="d1">"The Sole Survivor Policy is a regulation enacted by the United States after World War II to protect family members of military personnel from being placed in harm's way after the loss of their relatives."</data>
      <data key="d2">8119bda66f27343b4be177610dcff2af</data>
    </node>
    <node id="&quot;FEBRUARY 27, 2020&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"February 27, 2020, marks a date during the ongoing struggle against the coronavirus, reflecting on the challenges faced by individuals and the community."</data>
      <data key="d2">8119bda66f27343b4be177610dcff2af</data>
    </node>
    <node id="&quot;WECHAT&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">WeChat is a versatile messaging and social media platform that serves multiple purposes for its users. It is primarily used for communication, allowing individuals to connect with one another, share updates, and facilitate various transactions, including the purchase of medicine, particularly during quarantine periods. Additionally, WeChat has become a space for users to express themselves, as seen in the narrator's use of the platform to upload diary entries after losing access to Weibo. The platform also plays a significant role in social activism, as evidenced by the circulation of a letter of appeal regarding migrant workers. Furthermore, users share their thoughts and experiences on WeChat, including posts related to the coronavirus outbreak, highlighting its importance as a tool for information dissemination and community engagement.</data>
      <data key="d2">2014d81b9f4aeb008dab606a9f719b7a,54353bad2befd9d61191dd25ba0263f5,8119bda66f27343b4be177610dcff2af,8475b5acce1676914c613935d50901d6</data>
    </node>
    <node id="&quot;SOUTHERN CITY NEWS&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"Southern City News" is a media organization that focuses on providing updates and profiles related to the coronavirus situation. It has notably highlighted the human aspect of the crisis by profiling the efforts of a doctor attempting to save a coronavirus patient. Through its coverage, "Southern City News" aims to inform the public about the ongoing challenges and personal stories arising from the pandemic.</data>
      <data key="d2">3d6a788010fe75ade47b4927dc7a6c2c,8119bda66f27343b4be177610dcff2af</data>
    </node>
    <node id="&quot;HELP HOTLINE&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"The Help Hotline is a service set up to assist individuals from out of town who are stuck in Wuhan during the coronavirus outbreak."</data>
      <data key="d2">3d6a788010fe75ade47b4927dc7a6c2c</data>
    </node>
    <node id="&quot;JOURNALISTS&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Journalists in China are portrayed as brave individuals who seek to uncover the truth about the coronavirus outbreak and the government's response."</data>
      <data key="d2">3d6a788010fe75ade47b4927dc7a6c2c</data>
    </node>
    <node id="&quot;ZHU RONGJI&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Zhu Rongji is a former Chinese Premier known for his emphasis on independent thinking, as expressed in a speech in Shanghai."</data>
      <data key="d2">39d6ae4d79ba80953eb86122bce3240d</data>
    </node>
    <node id="&quot;JIANG HONG&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Jiang Hong is a veteran writer whose philosophy on independent thought has influenced the narrator's views."</data>
      <data key="d2">39d6ae4d79ba80953eb86122bce3240d</data>
    </node>
    <node id="&quot;YI ZHONGTIAN&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Yi Zhongtian is a classmate of the narrator who shares similar views on the nature of radical groups and their inability to accept differing opinions."</data>
      <data key="d2">39d6ae4d79ba80953eb86122bce3240d</data>
    </node>
    <node id="&quot;THE DIARY&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"The Diary" is a personal record that chronicles the author's experiences and reflections during the coronavirus outbreak. It serves as a narrative of the narrator's daily life, capturing their thoughts and observations throughout this challenging period. Through its entries, "The Diary" provides insight into the emotional and social impacts of the pandemic, offering a unique perspective on the author's journey during these unprecedented times.</data>
      <data key="d2">1a74ad918264f9c92231f7eea81aa970,39d6ae4d79ba80953eb86122bce3240d</data>
    </node>
    <node id="&quot;PROFESSOR LIU LIANG&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Professor Liu Liang is a researcher conducting autopsies on novel coronavirus victims to further understand the disease and improve treatment strategies."</data>
      <data key="d2">22ab7ca013baeeffead27cc8cbcbae9f</data>
    </node>
    <node id="&quot;ACUTE RESPIRATORY DISTRESS SYNDROME (ARDS)&quot;">
      <data key="d0">"CONCEPT"</data>
      <data key="d1">"ARDS is a severe condition that can occur in coronavirus patients, characterized by fluid accumulation in the lungs, complicating treatment."</data>
      <data key="d2">22ab7ca013baeeffead27cc8cbcbae9f</data>
    </node>
    <node id="&quot;PROFESSOR LIU&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Professor Liu is a researcher working on treatment and preventive strategies for the coronavirus, whose efforts are crucial for breakthroughs in understanding the virus."</data>
      <data key="d2">63fc0690d8e8e6407e5bd58f20230a80</data>
    </node>
    <node id="&quot;EAST LAKE&quot;">
      <data key="d0">"GEO"</data>
      <data key="d1">East Lake is a geographical location situated in Wuhan, renowned for its natural beauty. While it is described as desolate and empty during the spring season in some accounts, other descriptions highlight its scenic allure and the beauty it offers, particularly in spring. This contrast suggests that East Lake can evoke a sense of solitude as well as a point of reflection, especially for individuals like the narrator and Fang Fang, who find inspiration in its picturesque surroundings during this time of year. Overall, East Lake is characterized as a significant and beautiful area in Wuhan, appreciated for its tranquil and reflective qualities.</data>
      <data key="d2">3e8474bb1550779641628567633011fa,4a02f8de11375d220370828d6659eaf3,63fc0690d8e8e6407e5bd58f20230a80</data>
    </node>
    <node id="&quot;BLUE SKY AID TEAM&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"The Blue Sky Aid Team is a humanitarian organization that provided aid to Wuhan during the coronavirus outbreak, returning home to a warm welcome from the local community."</data>
      <data key="d2">48f71f719bc3d7a90495615cc8668f0e</data>
    </node>
    <node id="&quot;POLICE OFFICERS&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"Police Officers in Wuhan have been on the front lines of the outbreak, ensuring public safety and assisting in medical transport during the crisis."</data>
      <data key="d2">48f71f719bc3d7a90495615cc8668f0e</data>
    </node>
    <node id="&quot;NOVEL CORONAVIRUS OUTBREAK&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"The Novel Coronavirus Outbreak refers to the pandemic situation that began in Wuhan, leading to widespread infections and significant public health challenges."</data>
      <data key="d2">48f71f719bc3d7a90495615cc8668f0e</data>
    </node>
    <node id="&quot;WUHAN MUNICIPAL HEALTH COMMISSION&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">The Wuhan Municipal Health Commission is the governmental body responsible for public health reporting and management in Wuhan. It has faced scrutiny for delays in responding to the outbreak of a virus, despite receiving reports about the virus's spread. The Commission plays a crucial role in overseeing public health initiatives and managing health-related information within the city.</data>
      <data key="d2">48f71f719bc3d7a90495615cc8668f0e,94f757b20bd5e5a1834b6d4ae6d20dae</data>
    </node>
    <node id="&quot;JINYINTAN HOSPITAL&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"Jinyintan Hospital is another medical facility in Wuhan that was involved in the investigation of the virus and its transmission."</data>
      <data key="d2">94f757b20bd5e5a1834b6d4ae6d20dae</data>
    </node>
    <node id="&quot;CHILDREN&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Children are among the most affected by the coronavirus outbreak, with many orphaned or separated from their parents due to the epidemic."</data>
      <data key="d2">94f757b20bd5e5a1834b6d4ae6d20dae</data>
    </node>
    <node id="&quot;PSYCHOLOGICAL INTERVENTION&quot;">
      <data key="d0">"CONCEPT"</data>
      <data key="d1">"Psychological Intervention refers to the support and care needed for children affected by the trauma of losing parents during the outbreak."</data>
      <data key="d2">94f757b20bd5e5a1834b6d4ae6d20dae</data>
    </node>
    <node id="&quot;DIRECTOR JIANG XUEQING&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Director Jiang Xueqing was a respected medical professional at Wuhan Central Hospital, known for his kindness and strong principles, who tragically passed away during the epidemic."</data>
      <data key="d2">2d702d808dc0983b5a009535ca71a6c6</data>
    </node>
    <node id="&quot;CHINESE PHYSICIAN PRIZE&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"The Chinese Physician Prize is a prestigious award received by Director Jiang Xueqing, recognizing his contributions as a specialist in breast and thyroid cancer."</data>
      <data key="d2">2d702d808dc0983b5a009535ca71a6c6</data>
    </node>
    <node id="&quot;LI YUEHUA&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Li Yuehua is a healer known for his unconventional method of treating the novel coronavirus using acupuncture points, reportedly without protective gear, and is a subject of public debate regarding his medical credentials."</data>
      <data key="d2">68d1018c902661392b4e20435e4961ad</data>
    </node>
    <node id="&quot;DENG XIAOPING&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Deng Xiaoping was a Chinese leader known for his pragmatic approach to governance, famously stating that the effectiveness of a method is more important than its origin."</data>
      <data key="d2">68d1018c902661392b4e20435e4961ad</data>
    </node>
    <node id="&quot;INVESTIGATIVE REPORTS&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"Investigative reports are efforts by journalists to document and analyze the events surrounding the coronavirus outbreak in Wuhan, which are deemed crucial for historical understanding."</data>
      <data key="d2">c8e229d8fbd4f477126682d1b67e1bfd</data>
    </node>
    <node id="&quot;ZENG GUANG&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Zeng Guang is a journalist who expressed frustration over the lack of awareness regarding key individuals involved in the outbreak response."</data>
      <data key="d2">2014d81b9f4aeb008dab606a9f719b7a</data>
    </node>
    <node id="&quot;ZHANG JIXIAN&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Zhang Jixian is another key figure in the outbreak response who was not recognized in the media coverage."</data>
      <data key="d2">2014d81b9f4aeb008dab606a9f719b7a</data>
    </node>
    <node id="&quot;NINE MILLION WUHAN RESIDENTS&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">The "Nine Million Wuhan Residents" refers to the population of Wuhan, China, who were significantly impacted by the outbreak of a viral disease and the subsequent quarantine measures implemented during the crisis. These residents faced not only restrictions on their movement but also encountered considerable psychological and social challenges as a result of the quarantine. The situation highlighted the struggles of the nine million individuals living in Wuhan, as they navigated the difficulties posed by the outbreak and the measures taken to control it.</data>
      <data key="d2">2014d81b9f4aeb008dab606a9f719b7a,88c0aa6bc6e9484db48221e353dd96ab</data>
    </node>
    <node id="&quot;WU YOU&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Wu You is a volunteer who provided free medicine to citizens during the quarantine but faced repercussions for his actions."</data>
      <data key="d2">2014d81b9f4aeb008dab606a9f719b7a</data>
    </node>
    <node id="&quot;WANG YONG&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Wang Yong organized transportation for medical personnel during the quarantine, demonstrating community support."</data>
      <data key="d2">2014d81b9f4aeb008dab606a9f719b7a</data>
    </node>
    <node id="&quot;LIU XIAN&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Liu Xian traveled from Sichuan Province to provide free lunches for medical workers at Wuhan hospitals, showcasing volunteerism."</data>
      <data key="d2">2014d81b9f4aeb008dab606a9f719b7a</data>
    </node>
    <node id="&quot;SECONDARY DISASTER&quot;">
      <data key="d0">"CONCEPT"</data>
      <data key="d1">"Secondary Disaster refers to the potential economic and social issues that may arise following the initial outbreak and quarantine."</data>
      <data key="d2">2014d81b9f4aeb008dab606a9f719b7a</data>
    </node>
    <node id="&quot;DR. MEI ZHONGMING&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Dr. Mei Zhongming was an assistant director at Central Hospital, a skilled ophthalmologist who passed away due to the coronavirus, prompting condolences from the community."</data>
      <data key="d2">81ac5d9d3486351095e7556baea13868</data>
    </node>
    <node id="&quot;THE CORONAVIRUS EPIDEMIC&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"The Coronavirus Epidemic refers to the global health crisis caused by the spread of the coronavirus, significantly affecting public health and employment."</data>
      <data key="d2">81ac5d9d3486351095e7556baea13868</data>
    </node>
    <node id="&quot;LETTER OF APPEAL&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"The Letter of Appeal is a document circulating on WeChat that calls for government action to support migrant workers from Hubei during the coronavirus outbreak."</data>
      <data key="d2">81ac5d9d3486351095e7556baea13868</data>
    </node>
    <node id="&quot;DR. MEI&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Dr. Mei is a deceased doctor who was well-regarded in the community and is remembered by former patients and colleagues."</data>
      <data key="d2">75ac580f4988934d2ae2bfcfe1d611b4</data>
    </node>
    <node id="&quot;WUHAN SECOND HOSPITAL&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"Wuhan Second Hospital is a medical facility that was previously connected to Central Hospital and has a historical significance in the community."</data>
      <data key="d2">75ac580f4988934d2ae2bfcfe1d611b4</data>
    </node>
    <node id="&quot;HANKOU CATHOLIC HOSPITAL&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"Hankou Catholic Hospital is the earlier incarnation of Wuhan Second Hospital, with a 140-year history."</data>
      <data key="d2">75ac580f4988934d2ae2bfcfe1d611b4</data>
    </node>
    <node id="&quot;CHUTIAN NEW MEDIA&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"Chutian New Media is a news agency that reported on the situation at Central Hospital during the coronavirus outbreak."</data>
      <data key="d2">75ac580f4988934d2ae2bfcfe1d611b4</data>
    </node>
    <node id="&quot;THE CHINESE LUNAR NEW YEAR&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"The Chinese Lunar New Year is a significant cultural event that coincided with the early stages of the coronavirus outbreak, complicating the response efforts."</data>
      <data key="d2">16a55ea42b0f86d2dc184c5e8348f4d3</data>
    </node>
    <node id="&quot;THE HOSPITAL ADMINISTRATOR&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"The Hospital Administrator is a medical professional who provided aid in Wuhan and documented his experiences during the coronavirus outbreak."</data>
      <data key="d2">16a55ea42b0f86d2dc184c5e8348f4d3</data>
    </node>
    <node id="&quot;MY SECOND BROTHER&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"My Second Brother is a character who shares insights about shopping and family experiences during the pandemic, contributing to the narrative of daily life in Wuhan."</data>
      <data key="d2">70e8609ad54a494121d9ad67c2728482</data>
    </node>
    <node id="&quot;MISS X&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Miss X is a character who plays a role in coordinating the distribution of donated vegetables to residents during the pandemic."</data>
      <data key="d2">70e8609ad54a494121d9ad67c2728482</data>
    </node>
    <node id="&quot;ONLINE GROUP SHOPPING&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"Online Group Shopping is a trend that emerged during the pandemic, allowing individuals to adapt their shopping habits to the changing circumstances."</data>
      <data key="d2">70e8609ad54a494121d9ad67c2728482</data>
    </node>
    <node id="&quot;ADD MORE GROUP&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"Add More Group is a community-based online shopping group that facilitates grocery orders for its members during the pandemic."</data>
      <data key="d2">a1228c3edf57aa00b38f80de4ec91c5e</data>
    </node>
    <node id="&quot;PREMIER ZHOU ENLAI&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Premier Zhou Enlai was a prominent Chinese politician and the first Premier of the People's Republic of China, remembered for his leadership and influence during a significant period in Chinese history."</data>
      <data key="d2">a1228c3edf57aa00b38f80de4ec91c5e</data>
    </node>
    <node id="&quot;APRIL 5TH TIANANMEN SQUARE INCIDENT&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">The April 5th Tiananmen Square Incident refers to a significant episode of unrest in China that occurred following the death of Premier Zhou Enlai. This incident involved large-scale public mourning and protests, reflecting widespread discontent and political expression among the populace. It is recognized as a pivotal moment in Chinese political history, highlighting the tensions between the government and citizens during a time of national grief.</data>
      <data key="d2">05facbc17efc22acf453283e5f155f6b,a1228c3edf57aa00b38f80de4ec91c5e</data>
    </node>
    <node id="&quot;ZHOU ENLAI&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Zhou Enlai was a prominent Chinese politician and diplomat, known for his role in the Chinese Communist Party and as the first Premier of the People's Republic of China."</data>
      <data key="d2">05facbc17efc22acf453283e5f155f6b</data>
    </node>
    <node id="&quot;LEI FENG&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Lei Feng is a cultural icon in China, celebrated for his selflessness and dedication to helping others, often associated with good deeds and community service."</data>
      <data key="d2">05facbc17efc22acf453283e5f155f6b</data>
    </node>
    <node id="&quot;YU LUOKE&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Yu Luoke was a Chinese writer executed for his published works, remembered for his impact on the generation that experienced the Cultural Revolution."</data>
      <data key="d2">05facbc17efc22acf453283e5f155f6b</data>
    </node>
    <node id="&quot;WUHAN MUNICIPAL BUREAU OF CULTURE&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"The Wuhan Municipal Bureau of Culture is a government organization responsible for cultural affairs in Wuhan, China."</data>
      <data key="d2">05facbc17efc22acf453283e5f155f6b</data>
    </node>
    <node id="&quot;LI LIANG&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Li Liang was a physical therapist who passed away after battling health issues related to the coronavirus, leaving behind a young family."</data>
      <data key="d2">05facbc17efc22acf453283e5f155f6b</data>
    </node>
    <node id="&quot;TEMPORARY HOSPITAL IN HANYANG&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"The temporary hospital in Hanyang was established to treat patients during the coronavirus outbreak, providing necessary medical care."</data>
      <data key="d2">05facbc17efc22acf453283e5f155f6b</data>
    </node>
    <node id="&quot;BLOOD TEST&quot;">
      <data key="d0">"TECHNOLOGY"</data>
      <data key="d1">"A blood test is a medical procedure used to check for various health conditions, including the presence of antibodies related to the coronavirus."</data>
      <data key="d2">05facbc17efc22acf453283e5f155f6b</data>
    </node>
    <node id="&quot;DR. WANG GUANGFA&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">Dr. Wang Guangfa is a doctor from Beijing who gained prominence during the coronavirus outbreak as a member of the second group of specialists sent to Wuhan. He is known for making controversial statements regarding the virus, which have sparked discussions and debates. Additionally, Dr. Wang was personally infected by the coronavirus, and his experiences have contributed to the ongoing discourse on protective measures against the virus.</data>
      <data key="d2">b15e3136b1d250627e50da850c2559c5,b311864054a222e4315c575af55fca03</data>
    </node>
    <node id="&quot;PUBLIC OUTCRY&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"Public Outcry refers to the reactions of Wuhan citizens expressing their frustrations and concerns regarding the government's handling of the coronavirus outbreak."</data>
      <data key="d2">b15e3136b1d250627e50da850c2559c5</data>
    </node>
    <node id="&quot;JIANG YANYONG&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Jiang Yanyong is a figure who speaks out about the importance of truth in reporting, referencing past experiences from 2003."</data>
      <data key="d2">3f8704dd72f25d452df3dea8b46c7b79</data>
    </node>
    <node id="&quot;ZHANG WENKANG&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Zhang Wenkang is mentioned in the context of remarks that are perceived as incorrect, contrasting with other officials who can speak freely."</data>
      <data key="d2">3f8704dd72f25d452df3dea8b46c7b79</data>
    </node>
    <node id="&quot;SHANGHAI PULMONOLOGISTS&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"Shanghai Pulmonologists are a group of medical professionals who have traveled to Wuhan to provide assistance during a health crisis, demonstrating their commitment to patient care."</data>
      <data key="d2">527cd6baeddd98d25cc154a883dbb0ba</data>
    </node>
    <node id="&quot;HUBEI LOCAL OFFICIALS&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"Hubei Local Officials are the authorities in the Hubei province, responsible for managing the response to the health crisis in Wuhan."</data>
      <data key="d2">527cd6baeddd98d25cc154a883dbb0ba</data>
    </node>
    <node id="&quot;SANITATION WORKERS&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"Sanitation Workers are individuals who continue to work during the lockdown, maintaining cleanliness in Wuhan despite adverse conditions."</data>
      <data key="d2">527cd6baeddd98d25cc154a883dbb0ba</data>
    </node>
    <node id="&quot;THE SUPERMARKET&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"The Supermarket is a local store in Wuhan that managed to stay open during the lockdown, providing essential supplies to residents."</data>
      <data key="d2">527cd6baeddd98d25cc154a883dbb0ba</data>
    </node>
    <node id="&quot;HAINAN&quot;">
      <data key="d0">"GEO"</data>
