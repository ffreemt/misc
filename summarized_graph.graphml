      <data key="d3">1.0</data>
      <data key="d4">"The Narrator is a resident of Wuhan, directly experiencing the challenges posed by the health crisis in the city."</data>
      <data key="d5">ee747c2b3ef4b0d990341dab895eb81d</data>
    </edge>
