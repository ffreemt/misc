      <data key="d0">"PERSON"</data>
      <data key="d1">"The Painter is a mutual friend of the author and an entrepreneur who donated to support efforts during the outbreak."</data>
      <data key="d2">117c10f8d2ba000ee5b9e4627ab3dfb1</data>
    </node>
