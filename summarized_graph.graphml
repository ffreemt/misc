      <data key="d0">"PERSON"</data>
      <data key="d1">"The Cancer Patient is a woman from Hubei Cancer Hospital who faces challenges due to the healthcare system's focus on coronavirus patients."</data>
      <data key="d2">117c10f8d2ba000ee5b9e4627ab3dfb1</data>
    </node>
