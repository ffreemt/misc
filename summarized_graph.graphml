    <edge source="&quot;HUAZHONG UNIVERSITY OF SCIENCE AND TECHNOLOGY&quot;" target="&quot;THE CORONAVIRUS OUTBREAK&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"Huazhong University of Science and Technology has been impacted by the Coronavirus Outbreak, losing a professor to the virus."</data>
      <data key="d5">9b3b89c18ca285cf79a2fb9f3355fa5f</data>
    </edge>
    <edge source="&quot;HUAZHONG UNIVERSITY OF SCIENCE AND TECHNOLOGY&quot;" target="&quot;LIU XUERONG&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"Liu Xuerong is an alumnus of Huazhong University of Science and Technology, linking his educational background to his current role."</data>
      <data key="d5">a784bfe671571202f52c5445629f1862</data>
    </edge>
    <edge source="&quot;TONGJI HOSPITAL&quot;" target="&quot;PROFESSOR LIN ZHENGBIN&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"Professor Lin Zhengbin was a specialist at Tongji Hospital, contributing to its medical efforts before his passing."</data>
      <data key="d5">0f6f81b9c147f34def6ae3e90cdc4a8d</data>
    </edge>
    <edge source="&quot;SHANGHAI&quot;" target="&quot;THE EX-HUSBAND&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"The Ex-Husband was hospitalized in Shanghai, indicating a health-related connection to the city during the outbreak."</data>
      <data key="d5">ad43e1b0afe90e62a3b11cf82cc601cf</data>
    </edge>
    <edge source="&quot;SHANGHAI&quot;" target="&quot;N95 MASKS&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"The situation in Shanghai reflects the broader issue of price inflation for N95 masks during the health crisis."</data>
      <data key="d5">ee747c2b3ef4b0d990341dab895eb81d</data>
    </edge>
    <edge source="&quot;SHANGHAI&quot;" target="&quot;DR. ZHANG WENHONG&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"Dr. Zhang Wenhong provides guidance and medical advice in Shanghai, influencing public health responses to the coronavirus."</data>
      <data key="d5">82a05824c63b582fce46f3e7719ac6b6</data>
    </edge>
    <edge source="&quot;CHINESE NEW YEAR&quot;" target="&quot;THE OUTBREAK&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"The Outbreak has significantly impacted the celebration of Chinese New Year, preventing families from gathering and celebrating together."</data>
      <data key="d5">b7955b3f9e06c3774b23917a41090748</data>
    </edge>
    <edge source="&quot;CHINESE NEW YEAR&quot;" target="&quot;XIANG XINRAN&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"The outbreak occurred during the Chinese New Year, affecting the availability of support for elderly residents like Xiang Xinran."</data>
      <data key="d5">d493b79b718913aea1c87accaf09fc95</data>
    </edge>
    <edge source="&quot;CHINESE NEW YEAR&quot;" target="&quot;CORONAVIRUS&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"The coronavirus outbreak has affected the way people celebrate traditional events like Chinese New Year, leading to a somber atmosphere during the festivities."</data>
      <data key="d5">9d9621a0d3abed625eaaf2428ed7b0bb</data>
    </edge>
    <edge source="&quot;CHINESE NEW YEAR&quot;" target="&quot;THE AUTHOR&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"The Author faced significant health challenges just before the Chinese New Year, marking a personal struggle during this cultural event."</data>
      <data key="d5">ecdbc80cd38edf6145de3f6de4c35bb9</data>
    </edge>
    <edge source="&quot;XIAO LI&quot;" target="&quot;THE INFECTED COUPLE&quot;">
      <data key="d3">2.0</data>
      <data key="d4">"Xiao Li informed the narrator about the Infected Couple, establishing a relationship of communication regarding health concerns.""Xiao Li's information about the Infected Couple indicates a relationship of concern and community awareness regarding the outbreak."</data>
      <data key="d5">ad43e1b0afe90e62a3b11cf82cc601cf</data>
    </edge>
    <edge source="&quot;THE EX-HUSBAND&quot;" target="&quot;THE DAUGHTER&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"The Daughter had dinner with her father, the Ex-Husband, which is relevant to the health concerns surrounding the outbreak."</data>
      <data key="d5">ad43e1b0afe90e62a3b11cf82cc601cf</data>
    </edge>
    <edge source="&quot;N95 MASKS&quot;" target="&quot;THE HEALTH CRISIS&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"The demand for N95 Masks has surged due to the Health Crisis in Wuhan, highlighting the critical need for protective equipment."</data>
      <data key="d5">527cd6baeddd98d25cc154a883dbb0ba</data>
    </edge>
    <edge source="&quot;XU MIN&quot;" target="&quot;THE NARRATOR&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"Xu Min provided a face mask to the Narrator, which became crucial during the health crisis in Wuhan."</data>
      <data key="d5">ee747c2b3ef4b0d990341dab895eb81d</data>
    </edge>
    <edge source="&quot;THE NARRATOR&quot;" target="&quot;THE YOUNG MAN&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"The Narrator reflects on the Young Man's message about his health, which provides a moment of relief amidst the crisis."</data>
      <data key="d5">c74fab649e0e555219cd986800fcd418</data>
    </edge>
    <edge source="&quot;THE NARRATOR&quot;" target="&quot;THE WRITER&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"The Narrator critiques the Writer's comments about the virus, indicating a conflict in perspectives on the situation."</data>
      <data key="d5">c74fab649e0e555219cd986800fcd418</data>
    </edge>
    <edge source="&quot;THE NARRATOR&quot;" target="&quot;TA&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"TA expresses concern for the narrator's well-being, indicating a supportive relationship between the reader and the writer."</data>
      <data key="d5">dfb6674717edcd1b507ed271953bbf39</data>
    </edge>
    <edge source="&quot;THE NARRATOR&quot;" target="&quot;THE PAINTER FROM NEW YORK&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"The Painter from New York is a friend of the narrator who has made a significant donation to help during the coronavirus outbreak, showing solidarity and support."</data>
      <data key="d5">dfb6674717edcd1b507ed271953bbf39</data>
    </edge>
    <edge source="&quot;THE NARRATOR&quot;" target="&quot;THE PAINTER FROM GERMANY&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"The Painter from Germany is connected to the narrator through a past visit and has also committed to donating, indicating a shared concern for the situation in Wuhan."</data>
      <data key="d5">dfb6674717edcd1b507ed271953bbf39</data>
    </edge>
    <edge source="&quot;THE NARRATOR&quot;" target="&quot;CULTURAL REVOLUTION&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"The Narrator's formative years were heavily influenced by the Cultural Revolution, shaping their views and experiences."</data>
      <data key="d5">8addb1ba85a3edd5b064d6a87d33e55f</data>
    </edge>
