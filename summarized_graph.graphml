      <data key="d5">c14142f937484ddfb159db76b5886c12</data>
    </edge>
    <edge source="&quot;WUHAN&quot;" target="&quot;FEBRUARY 15, 2020&quot;">
      <data key="d3">1.0</data>
      <data key="d4">"February 15, 2020, is a date that signifies the ongoing struggles faced by Wuhan during the coronavirus outbreak."</data>
      <data key="d5">c14142f937484ddfb159db76b5886c12</data>
    </edge>
